---
const title = 'Admin – Invite User | YG-Auditors';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo2.png" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: #f7f5fb;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }
      .card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 4px 24px rgba(108,63,160,0.10);
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 2rem;
      }
      .logo img { width: 40px; height: 40px; object-fit: contain; }
      .logo span { font-weight: 700; font-size: 1.1rem; color: #3b1f6e; }
      h1 { font-size: 1.4rem; font-weight: 700; color: #3b1f6e; margin-bottom: 0.4rem; }
      .subtitle { font-size: 0.9rem; color: #7a6fa0; margin-bottom: 1.8rem; }
      label { display: block; font-size: 0.85rem; font-weight: 600; color: #3b1f6e; margin-bottom: 0.35rem; }
      input[type="email"], input[type="password"] {
        width: 100%;
        padding: 0.65rem 0.9rem;
        border: 1.5px solid #d0c8e8;
        border-radius: 0.5rem;
        font-size: 0.95rem;
        color: #2d1e5a;
        background: #faf9fe;
        outline: none;
        transition: border-color 0.2s;
        margin-bottom: 1.1rem;
      }
      input:focus { border-color: #6c3fa0; background: #fff; }
      button {
        width: 100%;
        background: #6c3fa0;
        color: #fff;
        border: none;
        border-radius: 0.5rem;
        padding: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.2rem;
      }
      button:hover { background: #5a3188; }
      button:disabled { background: #b09fd4; cursor: not-allowed; }
      .msg {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        display: none;
      }
      .msg.success { background: #edfaf1; color: #1a7a42; border: 1px solid #b7edcb; display: block; }
      .msg.error   { background: #fdeaea; color: #b91c1c; border: 1px solid #f8b4b4; display: block; }
      .section { display: none; }
      .section.active { display: block; }
      .logout-link {
        text-align: right;
        font-size: 0.8rem;
        margin-bottom: 1.2rem;
      }
      .logout-link a { color: #7a6fa0; cursor: pointer; text-decoration: underline; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="logo">
        <img src="/images/logo2.png" alt="YG-Auditors logo" />
        <span>YG-Auditors</span>
      </div>

      <!-- Login section -->
      <div id="loginSection" class="section active">
        <h1>Admin Login</h1>
        <p class="subtitle">Sign in with your admin account to invite users.</p>
        <form id="loginForm">
          <label for="loginEmail">Email</label>
          <input id="loginEmail" type="email" autocomplete="email" required placeholder="admin@example.com" />
          <label for="loginPassword">Password</label>
          <input id="loginPassword" type="password" autocomplete="current-password" required placeholder="••••••••" />
          <button type="submit" id="loginBtn">Sign in</button>
          <div id="loginMsg" class="msg"></div>
        </form>
      </div>

      <!-- Invite section -->
      <div id="inviteSection" class="section">
        <div class="logout-link"><a id="logoutBtn">Sign out</a></div>
        <h1>Invite User</h1>
        <p class="subtitle">Enter an email address — they'll receive an invitation link automatically.</p>
        <form id="inviteForm">
          <label for="inviteEmail">Email address</label>
          <input id="inviteEmail" type="email" autocomplete="off" required placeholder="user@example.com" />
          <button type="submit" id="inviteBtn">Send Invitation</button>
          <div id="inviteMsg" class="msg"></div>
        </form>
      </div>
    </div>

    <script>
      import { login, logout, getUser } from '@netlify/identity'

      const loginSection  = document.getElementById('loginSection')
      const inviteSection = document.getElementById('inviteSection')

      async function showUI() {
        const user = await getUser()
        if (user) {
          const roles = user.appMetadata?.roles ?? []
          if (roles.includes('admin')) {
            loginSection.classList.remove('active')
            inviteSection.classList.add('active')
            return
          }
          showMsg('loginMsg', 'error', 'Your account does not have the admin role.')
          await logout()
        } else {
          loginSection.classList.add('active')
          inviteSection.classList.remove('active')
        }
      }

      showUI()

      // Login
      document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault()
        const btn = document.getElementById('loginBtn')
        btn.disabled = true
        btn.textContent = 'Signing in…'
        clearMsg('loginMsg')
        try {
          const email    = document.getElementById('loginEmail').value.trim()
          const password = document.getElementById('loginPassword').value
          await login(email, password)
          await showUI()
        } catch (err) {
          showMsg('loginMsg', 'error', err.message || 'Login failed. Check your credentials.')
        } finally {
          btn.disabled = false
          btn.textContent = 'Sign in'
        }
      })

      // Logout
      document.getElementById('logoutBtn').addEventListener('click', async () => {
        await logout()
        showUI()
      })

      // Invite
      document.getElementById('inviteForm').addEventListener('submit', async (e) => {
        e.preventDefault()
        const btn   = document.getElementById('inviteBtn')
        const email = document.getElementById('inviteEmail').value.trim()
        btn.disabled = true
        btn.textContent = 'Sending…'
        clearMsg('inviteMsg')
        try {
          const user = await getUser()
          const token = user?.token?.access_token
          const res = await fetch('/.netlify/functions/invite', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              ...(token ? { Authorization: `Bearer ${token}` } : {}),
            },
            body: JSON.stringify({ email }),
          })
          const data = await res.json()
          if (!res.ok) throw new Error(data.error || 'Request failed')
          showMsg('inviteMsg', 'success', `Invitation sent to ${email}!`)
          document.getElementById('inviteEmail').value = ''
        } catch (err) {
          showMsg('inviteMsg', 'error', err.message || 'Could not send invitation.')
        } finally {
          btn.disabled = false
          btn.textContent = 'Send Invitation'
        }
      })

      function showMsg(id, type, text) {
        const el = document.getElementById(id)
        el.className = `msg ${type}`
        el.textContent = text
      }
      function clearMsg(id) {
        const el = document.getElementById(id)
        el.className = 'msg'
        el.textContent = ''
      }
    </script>
  </body>
</html>
