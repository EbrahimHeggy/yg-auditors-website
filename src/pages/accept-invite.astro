---
const title = 'Accept Invitation | YG-Auditors';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo2.png" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: #f7f5fb;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }
      .card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 4px 24px rgba(108,63,160,0.10);
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 400px;
        text-align: center;
      }
      .logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        margin-bottom: 2rem;
      }
      .logo img { width: 40px; height: 40px; object-fit: contain; }
      .logo span { font-weight: 700; font-size: 1.1rem; color: #3b1f6e; }
      h1 { font-size: 1.4rem; font-weight: 700; color: #3b1f6e; margin-bottom: 0.4rem; text-align: left; }
      .subtitle { font-size: 0.9rem; color: #7a6fa0; margin-bottom: 1.8rem; text-align: left; }
      label { display: block; font-size: 0.85rem; font-weight: 600; color: #3b1f6e; margin-bottom: 0.35rem; text-align: left; }
      input[type="password"] {
        width: 100%;
        padding: 0.65rem 0.9rem;
        border: 1.5px solid #d0c8e8;
        border-radius: 0.5rem;
        font-size: 0.95rem;
        color: #2d1e5a;
        background: #faf9fe;
        outline: none;
        transition: border-color 0.2s;
        margin-bottom: 1.1rem;
      }
      input:focus { border-color: #6c3fa0; background: #fff; }
      button {
        width: 100%;
        background: #6c3fa0;
        color: #fff;
        border: none;
        border-radius: 0.5rem;
        padding: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
      }
      button:hover { background: #5a3188; }
      button:disabled { background: #b09fd4; cursor: not-allowed; }
      .msg {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        display: none;
        text-align: left;
      }
      .msg.success { background: #edfaf1; color: #1a7a42; border: 1px solid #b7edcb; display: block; }
      .msg.error   { background: #fdeaea; color: #b91c1c; border: 1px solid #f8b4b4; display: block; }
      .spinner {
        border: 3px solid #e5dff5;
        border-top-color: #6c3fa0;
        border-radius: 50%;
        width: 2rem;
        height: 2rem;
        animation: spin 0.8s linear infinite;
        margin: 2rem auto;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      .home-link {
        display: inline-block;
        margin-top: 1.5rem;
        color: #6c3fa0;
        font-size: 0.9rem;
        text-decoration: none;
      }
      .home-link:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="logo">
        <img src="/images/logo2.png" alt="YG-Auditors logo" />
        <span>YG-Auditors</span>
      </div>

      <div id="loading"><div class="spinner"></div></div>

      <div id="formSection" style="display:none">
        <h1>Create Your Password</h1>
        <p class="subtitle">You've been invited. Set a password to activate your account.</p>
        <form id="acceptForm">
          <label for="newPassword">Password</label>
          <input id="newPassword" type="password" autocomplete="new-password" required minlength="8" placeholder="At least 8 characters" />
          <label for="confirmPassword">Confirm password</label>
          <input id="confirmPassword" type="password" autocomplete="new-password" required placeholder="Repeat your password" />
          <button type="submit" id="acceptBtn">Activate Account</button>
          <div id="formMsg" class="msg"></div>
        </form>
      </div>

      <div id="successSection" style="display:none">
        <p style="font-size:2.5rem;margin-bottom:1rem">🎉</p>
        <h1 style="text-align:center">Welcome!</h1>
        <p class="subtitle" style="text-align:center">Your account has been activated. You can now sign in.</p>
        <a href="/" class="home-link">← Back to home</a>
      </div>

      <div id="errorSection" style="display:none">
        <p style="font-size:2.5rem;margin-bottom:1rem">⚠️</p>
        <h1 style="text-align:center">Invalid Link</h1>
        <p class="subtitle" style="text-align:center" id="errorDetail">This invitation link is invalid or has expired.</p>
        <a href="/" class="home-link">← Back to home</a>
      </div>
    </div>

    <script>
      import { handleAuthCallback, acceptInvite } from '@netlify/identity'

      const loading       = document.getElementById('loading')
      const formSection   = document.getElementById('formSection')
      const successSection = document.getElementById('successSection')
      const errorSection  = document.getElementById('errorSection')

      let inviteToken = null

      async function init() {
        try {
          const result = await handleAuthCallback()
          if (result?.type === 'invite' && result.token) {
            inviteToken = result.token
            loading.style.display = 'none'
            formSection.style.display = 'block'
          } else if (result) {
            // Some other callback type (already handled elsewhere)
            window.location.href = '/'
          } else {
            // No hash token – show error
            loading.style.display = 'none'
            errorSection.style.display = 'block'
          }
        } catch (err) {
          loading.style.display = 'none'
          document.getElementById('errorDetail').textContent = err.message || 'Something went wrong.'
          errorSection.style.display = 'block'
        }
      }

      init()

      document.getElementById('acceptForm').addEventListener('submit', async (e) => {
        e.preventDefault()
        const password  = document.getElementById('newPassword').value
        const confirm   = document.getElementById('confirmPassword').value
        const btn       = document.getElementById('acceptBtn')
        const msg       = document.getElementById('formMsg')

        msg.className = 'msg'
        msg.textContent = ''

        if (password !== confirm) {
          msg.className = 'msg error'
          msg.textContent = 'Passwords do not match.'
          return
        }

        btn.disabled = true
        btn.textContent = 'Activating…'

        try {
          await acceptInvite(inviteToken, password)
          formSection.style.display = 'none'
          successSection.style.display = 'block'
        } catch (err) {
          msg.className = 'msg error'
          msg.textContent = err.message || 'Could not activate account. The link may have expired.'
          btn.disabled = false
          btn.textContent = 'Activate Account'
        }
      })
    </script>
  </body>
</html>
