---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Qualifications from '../components/Qualifications.astro';
import Industries from '../components/Industries.astro';
import Team from '../components/Team.astro';
import Consultant from '../components/Consultant.astro';
import Contact from '../components/Contact.astro';
import TrustBanner from '../components/TrustBanner.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import Process from '../components/Process.astro';

const lang = 'ar';
---

<Layout
  title="YG-Auditors | خدمات محاسبة ومراجعة احترافية في القاهرة، مصر"
  description="مكتب يوسف جلال للمحاسبة والمراجعة — خدمات مالية شاملة في المعادي، القاهرة. مراجعة وتدقيق، استشارات ضريبية، محاسبة، تأمينات اجتماعية، وتأسيس شركات."
  lang={lang}
>
  <Hero lang={lang} />
  <LogoMarquee lang={lang} />
  <TrustBanner lang={lang} />
  <About lang={lang} />
  <Services lang={lang} />
  <Process lang={lang} />
  <Qualifications lang={lang} />
  <Industries lang={lang} />
  <Team lang={lang} />
  <Consultant lang={lang} />
  <Contact lang={lang} />
</Layout>
