---
import teamData from '../data/team.json';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const headings = {
  en: { badge: 'Leadership', title: 'Meet Our Founder', sub: 'A qualified ACCA professional dedicated to delivering exceptional financial services across Egypt since 2015.' },
  ar: { badge: 'القيادة', title: 'تعرف على مؤسسنا', sub: 'محاسب قانوني مؤهل ACCA ملتزم بتقديم خدمات مالية استثنائية في جميع أنحاء مصر منذ عام 2015.' },
};
const h = headings[l] ?? headings.en;

const labels = {
  en: { about: 'About', qualifications: 'Memberships', specializations: 'Specializations', viewCert: 'View Certificate', founded: 'Founded', experience: 'Years Experience', clients: 'Clients+', certified: 'Certified' },
  ar: { about: 'نبذة', qualifications: 'العضويات المهنية', specializations: 'التخصصات', viewCert: 'عرض الشهادة', founded: 'سنة التأسيس', experience: 'سنوات خبرة', clients: 'عميل+', certified: 'معتمد دولياً' },
};
const lb = labels[l] ?? labels.en;
---

<section class="section team" id="team">
  <div class="container">

    <div class="section-header" data-gsap="team-header">
      <span class="badge">{h.badge}</span>
      <h2>{h.title}</h2>
      <div class="divider"></div>
      <p>{h.sub}</p>
    </div>

    {teamData.team.map((member) => (
      <div class="profile-chart" data-gsap="team-card">

        <!-- ── Top header strip ── -->
        <div class="profile-chart__header">
          <div class="profile-chart__photo-wrap">
            <img
              src={member.photo}
              alt={member.name}
              class="profile-chart__photo"
              onerror="this.src='/images/user.png'"
            />
            <span class="profile-chart__acca-badge">{member.credentials}</span>
          </div>

          <div class="profile-chart__identity">
            <div class="profile-chart__name-row">
              <h3 class="profile-chart__name">{l === 'ar' ? member.arabicName : member.name}</h3>
            </div>
            <p class="profile-chart__title">{member.role[l] ?? member.role.en}</p>
            <p class="profile-chart__designation">{member.designation}</p>
            <div class="profile-chart__socials">
              {member.social.linkedin && (
                <a href={member.social.linkedin} target="_blank" rel="noopener" class="profile-chart__social" aria-label="LinkedIn">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              )}
              {member.social.facebook && (
                <a href={member.social.facebook} target="_blank" rel="noopener" class="profile-chart__social" aria-label="Facebook">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  Facebook
                </a>
              )}
            </div>
          </div>

          <!-- Stats strip on the right -->
          <div class="profile-chart__stats">
            <div class="profile-chart__stat">
              <span class="profile-chart__stat-val">2015</span>
              <span class="profile-chart__stat-lbl">{lb.founded}</span>
            </div>
            <div class="profile-chart__stat">
              <span class="profile-chart__stat-val">10+</span>
              <span class="profile-chart__stat-lbl">{lb.experience}</span>
            </div>
            <div class="profile-chart__stat">
              <span class="profile-chart__stat-val">100+</span>
              <span class="profile-chart__stat-lbl">{lb.clients}</span>
            </div>
            <div class="profile-chart__stat">
              <span class="profile-chart__stat-val">ACCA</span>
              <span class="profile-chart__stat-lbl">{lb.certified}</span>
            </div>
          </div>
        </div>

        <!-- ── Chart body: 3 columns ── -->
        <div class="profile-chart__body">

          <!-- Col 1: About -->
          <div class="profile-chart__col">
            <h4 class="profile-chart__col-title">{lb.about}</h4>
            <p class="profile-chart__bio">{member.bio[l] ?? member.bio.en}</p>
          </div>

          <div class="profile-chart__divider"></div>

          <!-- Col 2: Qualifications -->
          <div class="profile-chart__col">
            <h4 class="profile-chart__col-title">{lb.qualifications}</h4>
            <ul class="profile-chart__qual-list">
              {member.qualifications.map((q) => (
                <li class="profile-chart__qual-item">
                  <span class="profile-chart__qual-check">✓</span>
                  {q}
                </li>
              ))}
            </ul>

            {member.certificate && (
              <button
                class="profile-chart__cert-btn"
                onclick={`document.getElementById('team-cert-modal').showModal()`}
                aria-label="View ACCA Certificate"
              >
                <img src={member.certificate} alt="ACCA Certificate" class="profile-chart__cert-thumb" />
                <span>{lb.viewCert}</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </button>
            )}
          </div>

          <div class="profile-chart__divider"></div>

          <!-- Col 3: Specializations -->
          <div class="profile-chart__col">
            <h4 class="profile-chart__col-title">{lb.specializations}</h4>
            <div class="profile-chart__spec-grid">
              {member.specializations.map((s) => (
                <div class="profile-chart__spec-card">{s}</div>
              ))}
            </div>
          </div>

        </div>
      </div>
    ))}

  </div>
</section>

<!-- Certificate modal -->
{teamData.team.filter(m => m.certificate).map((member) => (
  <dialog id="team-cert-modal" class="cert-modal">
    <button class="cert-modal__close" onclick="document.getElementById('team-cert-modal').close()" aria-label="Close">&times;</button>
    <img src={member.certificate} alt="ACCA Certificate" class="cert-modal__img" />
  </dialog>
))}

<style>
  /* ── Profile chart card ── */
  .profile-chart {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg), var(--shadow-gold);
    max-width: 960px;
    margin-inline: auto;
  }

  /* ── Header strip ── */
  .profile-chart__header {
    background: var(--color-bg);
    padding: 2.5rem 2.5rem 2rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2rem;
    align-items: start;
  }

  .profile-chart__photo-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .profile-chart__photo {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 4px solid rgba(139, 92, 200, 0.35);
    background: var(--color-bg-alt);
    display: block;
  }
  .profile-chart__acca-badge {
    position: absolute;
    bottom: -6px;
    right: -6px;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-white);
  }

  .profile-chart__identity {
    color: var(--color-white);
  }
  .profile-chart__name-row { margin-bottom: 0.25rem; }
  .profile-chart__name {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-white);
    margin: 0;
  }
  [dir="rtl"] .profile-chart__name { font-family: var(--font-arabic-serif); }
  .profile-chart__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: 0.2rem;
  }
  .profile-chart__designation {
    font-size: 0.82rem;
    color: var(--color-text-medium);
    margin-bottom: 1.25rem;
  }
  .profile-chart__socials {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .profile-chart__social {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(139, 92, 200, 0.14);
    color: var(--color-text-dark);
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(139, 92, 200, 0.30);
    transition: var(--transition);
  }
  .profile-chart__social:hover {
    background: rgba(139, 92, 200, 0.24);
  }

  /* Stats strip */
  .profile-chart__stats {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-width: 120px;
  }
  .profile-chart__stat {
    text-align: center;
    background: rgba(139, 92, 200, 0.12);
    border: 1px solid rgba(139, 92, 200, 0.25);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.75rem;
  }
  .profile-chart__stat-val {
    display: block;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-dark);
    line-height: 1;
    margin-bottom: 0.2rem;
  }
  .profile-chart__stat-lbl {
    display: block;
    font-size: 0.68rem;
    color: var(--color-text-medium);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Chart body ── */
  .profile-chart__body {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
  }
  .profile-chart__col {
    padding: 2rem 2rem;
  }
  .profile-chart__divider {
    width: 1px;
    background: var(--color-border);
    margin-block: 1.5rem;
  }
  .profile-chart__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-primary);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .profile-chart__col-title::before {
    content: '';
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Bio col */
  .profile-chart__bio {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-medium);
  }

  /* Qualifications col */
  .profile-chart__qual-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-bottom: 1.5rem;
  }
  .profile-chart__qual-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--color-text-medium);
    line-height: 1.45;
  }
  .profile-chart__qual-check {
    color: var(--color-primary);
    font-weight: 800;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  /* Certificate thumbnail button */
  .profile-chart__cert-btn {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--color-primary-50);
    border: 1px solid rgba(108, 63, 160, 0.25);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    transition: var(--transition);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-primary);
    width: 100%;
  }
  .profile-chart__cert-btn:hover {
    background: rgba(108, 63, 160, 0.1);
    border-color: var(--color-primary);
  }
  .profile-chart__cert-thumb {
    width: 38px;
    height: 52px;
    object-fit: cover;
    border-radius: 3px;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  /* Specializations col */
  .profile-chart__spec-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .profile-chart__spec-card {
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-100);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    text-align: center;
    line-height: 1.3;
    transition: var(--transition);
  }
  .profile-chart__spec-card:hover {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
  }

  /* Certificate modal */
  .cert-modal {
    border: none;
    border-radius: var(--radius-xl);
    padding: 1rem;
    max-width: 90vw;
    max-height: 90vh;
    box-shadow: var(--shadow-xl);
    position: fixed;
  }
  .cert-modal::backdrop {
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(6px);
  }
  .cert-modal__close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-light);
  }
  .cert-modal__close:hover { color: var(--color-text-dark); }
  .cert-modal__img {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    border-radius: var(--radius-lg);
    margin-top: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .profile-chart__header {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
    }
    .profile-chart__stats {
      grid-column: 1 / -1;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-between;
      min-width: unset;
    }
    .profile-chart__stat { flex: 1; min-width: 80px; }
    .profile-chart__body {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .profile-chart__divider { width: 100%; height: 1px; margin-inline: 0; }
    .profile-chart__spec-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .profile-chart__header { padding: 1.75rem 1.25rem 1.5rem; gap: 1.25rem; }
    .profile-chart__col { padding: 1.5rem 1.25rem; }
    .profile-chart__spec-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.create({
    trigger: '#team',
    start: 'top 82%',
    once: true,
    onEnter: () => {
      gsap.fromTo('[data-gsap="team-header"]',
        { autoAlpha: 0, y: 40 },
        { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out' }
      );
      gsap.fromTo('[data-gsap="team-card"]',
        { autoAlpha: 0, y: 60 },
        { autoAlpha: 1, y: 0, duration: 0.85, ease: 'power3.out', delay: 0.2 }
      );
      gsap.fromTo('.profile-chart__spec-card',
        { autoAlpha: 0, scale: 0.9 },
        { autoAlpha: 1, scale: 1, duration: 0.4, stagger: 0.08, ease: 'back.out(1.3)', delay: 0.6 }
      );
    },
  });
</script>
