---
import { getEntry } from 'astro:content';
import LivingEarth from './LivingEarth.astro';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;

const en = await getEntry('hero', 'en');
const ar = await getEntry('hero', 'ar');
const c = (lang === 'ar' ? ar?.data : en?.data) ?? en!.data;
const headline = c.phrases[0];
---

<section class="hero" id="intro">
  <div class="hero__earth-bg" aria-hidden="true">
    <LivingEarth id="hero-earth" variant="hero" scrollTarget="#intro" />
    <div class="hero__earth-scrim"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <span class="hero__badge" data-gsap="hero-badge">{c.badge}</span>
      <h1 class="hero__headline" data-gsap="hero-headline">
        <span
          class="hero__typewriter"
          id="hero-typewriter"
          data-phrases={JSON.stringify(c.phrases)}
        >{headline}</span><span class="hero__cursor" aria-hidden="true">|</span>
      </h1>
      <p class="hero__sub" data-gsap="hero-sub">{c.subheadline}</p>
      <div class="hero__actions" data-gsap="hero-actions">
        <a href="#services" class="btn btn-mint">{c.cta1}</a>
       
      
      <div class="hero__badge-float" data-gsap="hero-float-badge">
        <span class="hero__badge-float-icon">✓</span>
        <span>ACCA Certified</span>
      </div>
      </div>
    </div>
  </div>

  <div class="hero__stats">
    <div class="container">
      <div class="hero__stats-grid">
        {c.stats.map((stat) => (
          <div class="hero__stat" data-gsap="hero-stat">
            <span
              class="hero__stat-value"
              data-count={stat.count !== null ? String(stat.count) : undefined}
              data-before={stat.before || undefined}
              data-after={stat.after || undefined}
              style={`min-width:${stat.value.length}ch`}
            >{stat.value}</span>
            <span class="hero__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Hero: living Earth in deep space, mint accent (scoped to this section only) ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background: #03040C;
    padding-block-start: 72px;
  }

  /* ── Full-bleed Earth background ── */
  .hero__earth-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero__earth-scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 60% at 20% 45%, rgba(3, 4, 12, 0.92) 0%, rgba(3, 4, 12, 0.55) 45%, transparent 70%),
      linear-gradient(180deg, rgba(3, 4, 12, 0.35) 0%, rgba(3, 4, 12, 0.15) 40%, rgba(3, 4, 12, 0.75) 100%);
  }

  /* ── Layout ── */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    padding-block: 6rem;
  }
  .hero__content {
    max-width: 620px;
  }

  /* ── Badge ── */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(94, 234, 212, 0.10);
    color: rgba(170, 255, 235, 0.92);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.4rem 1.2rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(94, 234, 212, 0.28);
    margin-bottom: 1.75rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Headline ── */
  .hero__headline {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.08;
    margin-bottom: 1.35rem;
    background: linear-gradient(145deg, #FFFFFF 0%, #BFFCEE 48%, #5EEAD4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    min-height: 3.3em;
    display: block;
  }
  [dir="rtl"] .hero__headline { font-family: var(--font-arabic-serif); }

  .hero__typewriter { display: inline; }

  .hero__cursor {
    display: inline;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.65);
    color: rgba(255, 255, 255, 0.65);
    font-weight: 300;
    margin-inline-start: 2px;
    animation: cursor-blink 1s step-end infinite;
  }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__cursor { animation: none; }
  }

  /* ── Sub ── */
  .hero__sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.62);
    margin-bottom: 2.25rem;
    max-width: 520px;
    line-height: 1.8;
  }

  /* ── Actions ── */
  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.25rem;
  }

  /* ── Mint button variants (scoped to Hero only) ── */
  .btn-mint {
    background: linear-gradient(135deg, #14B8A6 0%, #5EEAD4 100%);
    color: #03241F;
    border-color: transparent;
    box-shadow: 0 4px 18px rgba(94, 234, 212, 0.30);
  }
  .btn-mint:hover {
    background: linear-gradient(135deg, #2DD4BF 0%, #99F6E4 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(94, 234, 212, 0.40);
  }
  .btn-outline-mint {
    background: rgba(94, 234, 212, 0.08);
    color: rgba(190, 255, 240, 0.92);
    border-color: rgba(94, 234, 212, 0.30);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .btn-outline-mint:hover {
    background: rgba(94, 234, 212, 0.16);
    border-color: rgba(94, 234, 212, 0.55);
    color: #FFFFFF;
  }

  /* ── Float badge (glass on dark) ── */
  .hero__badge-float {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(94, 234, 212, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: var(--radius-lg);
    padding: 0.7rem 1.2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(94, 234, 212, 0.10);
    font-weight: 700;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(94, 234, 212, 0.22);
  }
  .hero__badge-float-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #14B8A6, #5EEAD4);
    color: #03241F;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 800;
  }

  /* ── Stats bar (dark glass) ── */
  .hero__stats {
    position: relative;
    z-index: 1;
    background: rgba(94, 234, 212, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(94, 234, 212, 0.10);
    padding: 2.25rem 0;
  }
  .hero__stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    border-right: 1px solid rgba(94, 234, 212, 0.10);
  }
  .hero__stat:last-child { border-right: none; }
  .hero__stat-value {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    text-align: center;
    background: linear-gradient(135deg, #FFFFFF 0%, #5EEAD4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero__stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.48);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero__inner { justify-content: center; text-align: center; padding-block: 5rem; }
    .hero__content { display: flex; flex-direction: column; align-items: center; }
    .hero__sub { margin-inline: auto; }
    .hero__actions { justify-content: center; }
    .hero__stats-grid { grid-template-columns: repeat(2, 1fr); }
    .hero__stat { border-right: none; }
  }
  @media (max-width: 480px) {
    .hero__stats-grid { grid-template-columns: repeat(2, 1fr); }
    .hero__headline { min-height: 4.5em; }
  }
</style>

<script>
  import gsap from 'gsap';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Count-up helper ── */
  function countUp(el: HTMLElement) {
    const target = parseInt(el.dataset.count ?? '0', 10);
    const before = el.dataset.before ?? '';
    const after  = el.dataset.after  ?? '';
    const obj = { val: 0 };
    gsap.to(obj, {
      val: target,
      duration: 2,
      ease: 'power2.out',
      onUpdate() { el.textContent = before + Math.round(obj.val) + after; },
      onComplete() { el.textContent = before + target + after; },
    });
  }

  /* ── Typewriter ── */
  function initTypewriter() {
    if (reduced) return;
    const maybeEl = document.getElementById('hero-typewriter');
    if (!maybeEl) return;
    const el: HTMLElement = maybeEl;
    const phrases: string[] = JSON.parse(el.dataset.phrases ?? '[]');
    if (phrases.length < 2) return;

    let phraseIdx = 0;
    let charIdx = phrases[0].length; // start already showing phrase 0
    let isDeleting = false;

    function tick() {
      const current = phrases[phraseIdx];

      if (!isDeleting && charIdx === current.length) {
        // Done typing — pause 2.2s then delete
        setTimeout(() => { isDeleting = true; tick(); }, 2200);
        return;
      }

      if (isDeleting && charIdx === 0) {
        // Done deleting — next phrase, pause 400ms
        phraseIdx = (phraseIdx + 1) % phrases.length;
        isDeleting = false;
        setTimeout(tick, 400);
        return;
      }

      if (isDeleting) {
        charIdx--;
        el.textContent = current.slice(0, charIdx);
        setTimeout(tick, 28);
      } else {
        charIdx++;
        el.textContent = phrases[phraseIdx].slice(0, charIdx);
        setTimeout(tick, 55);
      }
    }

    // Wait then start deleting the initial rendered phrase
    setTimeout(() => { isDeleting = true; tick(); }, 2200);
  }

  /* ── GSAP entrance ── */
  gsap.set('[data-gsap="hero-badge"]',       { autoAlpha: 0, y: 24 });
  /* Headline is the LCP element — kept visible (no autoAlpha) so it paints immediately instead of waiting on this script; it still slides up. */
  gsap.set('[data-gsap="hero-headline"]',    { y: 32 });
  gsap.set('[data-gsap="hero-sub"]',         { autoAlpha: 0, y: 24 });
  gsap.set('[data-gsap="hero-actions"]',     { autoAlpha: 0, y: 20 });
  gsap.set('[data-gsap="hero-float-badge"]', { autoAlpha: 0, scale: 0.8 });
  gsap.set('[data-gsap="hero-stat"]',        { autoAlpha: 0, y: 20 });

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.1 });

  tl.to('[data-gsap="hero-badge"]',       { autoAlpha: 1, y: 0, duration: 0.55 })
    .to('[data-gsap="hero-headline"]',    { y: 0, duration: 0.7  }, '-=0.3')
    .to('[data-gsap="hero-sub"]',         { autoAlpha: 1, y: 0, duration: 0.55 }, '-=0.35')
    .to('[data-gsap="hero-actions"]',     { autoAlpha: 1, y: 0, duration: 0.5  }, '-=0.25')
    .to('[data-gsap="hero-float-badge"]', { autoAlpha: 1, scale: 1, duration: 0.45, ease: 'back.out(1.4)' }, '-=0.2')
    .to('[data-gsap="hero-stat"]',        { autoAlpha: 1, y: 0, duration: 0.45, stagger: 0.1 }, '-=0.2')
    .add(() => {
      /* Count-up starts when stats animate in */
      document.querySelectorAll<HTMLElement>('.hero__stat-value[data-count]').forEach(countUp);
      /* Typewriter starts after headline is visible */
      initTypewriter();
    });
</script>
