---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;

const content = {
  en: {
    badge: 'Founded in 2015 · Cairo, Egypt',
    phrases: [
      'Professional Accounting & Auditing Services',
      'Trusted by 100+ Businesses Across Egypt',
      'ACCA-Certified Financial Experts',
      'Your Partner in Compliance & Growth',
    ],
    subheadline: 'We are a professional group of accountants and auditors who provide our clients a full range of financial services.',
    cta1: 'Our Services',
    cta2: 'Download Profile',
    stats: [
      { value: '10+', label: 'Years of Experience',  count: 10,  before: '',  after: '+' },
      { value: '100+', label: 'Clients Served',      count: 100, before: '',  after: '+' },
      { value: '5',   label: 'Core Services',        count: 5,   before: '',  after: ''  },
      { value: 'ACCA', label: 'Certified',           count: null, before: '', after: ''  },
    ],
  },
  ar: {
    badge: 'تأسس عام 2015 · القاهرة، مصر',
    phrases: [
      'خدمات محاسبة ومراجعة احترافية',
      'موثوق به من أكثر من 100 شركة في مصر',
      'خبراء ماليون معتمدون من ACCA',
      'شريكك في الامتثال والنمو',
    ],
    subheadline: 'نحن مجموعة متخصصة من المحاسبين والمراجعين نقدم لعملائنا مجموعة متكاملة من الخدمات المالية.',
    cta1: 'خدماتنا',
    cta2: 'تحميل الملف التعريفي',
    stats: [
      { value: '+10',  label: 'سنوات من الخبرة',   count: 10,  before: '+', after: '' },
      { value: '+100', label: 'عميل تم خدمته',     count: 100, before: '+', after: '' },
      { value: '5',   label: 'خدمات أساسية',       count: 5,   before: '',  after: '' },
      { value: 'ACCA', label: 'معتمد دولياً',      count: null, before: '', after: '' },
    ],
  },
};

const c = content[lang as keyof typeof content] ?? content.en;
const headline = c.phrases[0];
---

<section class="hero" id="intro">
  <div class="hero__bg-decoration" aria-hidden="true">
    <div class="hero__circle hero__circle--1"></div>
    <div class="hero__circle hero__circle--2"></div>
    <div class="hero__circle hero__circle--3"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <span class="hero__badge" data-gsap="hero-badge">{c.badge}</span>
      <h1 class="hero__headline" data-gsap="hero-headline">
        <span
          class="hero__typewriter"
          id="hero-typewriter"
          data-phrases={JSON.stringify(c.phrases)}
        >{headline}</span><span class="hero__cursor" aria-hidden="true">|</span>
      </h1>
      <p class="hero__sub" data-gsap="hero-sub">{c.subheadline}</p>
      <div class="hero__actions" data-gsap="hero-actions">
        <a href="#services" class="btn btn-primary">{c.cta1}</a>
        <a href="/data/yg-auditors.pdf" class="btn btn-outline-white" download>{c.cta2}</a>
      </div>
    </div>

    <div class="hero__visual" data-gsap="hero-image">
      <div class="hero__image-wrap">
        <img
          src="/images/intro-img1.png"
          alt="YG-Auditors professional team"
          class="hero__intro-img"
          width="520"
          height="520"
          loading="eager"
        />
        <div class="hero__badge-float" data-gsap="hero-float-badge">
          <span class="hero__badge-float-icon">✓</span>
          <span>ACCA Certified</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__stats">
    <div class="container">
      <div class="hero__stats-grid">
        {c.stats.map((stat) => (
          <div class="hero__stat" data-gsap="hero-stat">
            <span
              class="hero__stat-value"
              data-count={stat.count !== null ? String(stat.count) : undefined}
              data-before={stat.before || undefined}
              data-after={stat.after || undefined}
            >{stat.value}</span>
            <span class="hero__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Hero: dark, dramatic ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse 70% 80% at 75% 25%, rgba(108, 63, 160, 0.30) 0%, transparent 65%),
      radial-gradient(ellipse 55% 60% at 15% 80%, rgba(80, 50, 180, 0.18) 0%, transparent 60%),
      linear-gradient(160deg, #08091A 0%, #100D2E 45%, #1B1248 70%, #08091A 100%);
    padding-block-start: 72px;
  }

  /* ── Glowing circles ── */
  .hero__bg-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero__circle {
    position: absolute;
    border-radius: 50%;
  }
  .hero__circle--1 {
    width: 700px; height: 700px; top: -250px; right: -250px; opacity: 0.85;
    border: 1.5px solid rgba(140, 70, 220, 0.22);
    background: radial-gradient(circle at 30% 30%, rgba(108, 63, 160, 0.18) 0%, transparent 65%);
  }
  .hero__circle--2 {
    width: 450px; height: 450px; bottom: -180px; left: -120px; opacity: 0.65;
    border: 1px solid rgba(100, 100, 240, 0.20);
    background: radial-gradient(circle at 70% 70%, rgba(80, 100, 240, 0.12) 0%, transparent 65%);
  }
  .hero__circle--3 {
    width: 260px; height: 260px; top: 38%; right: 28%; opacity: 0.45;
    border: 1px solid rgba(149, 97, 200, 0.30);
    background: radial-gradient(circle, rgba(108, 63, 160, 0.10) 0%, transparent 70%);
  }

  /* ── Layout ── */
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-block: 5rem;
  }

  /* ── Badge ── */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.4rem 1.2rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.14);
    margin-bottom: 1.75rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Headline ── */
  .hero__headline {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.08;
    margin-bottom: 1.35rem;
    background: linear-gradient(145deg, #FFFFFF 0%, #D4BAF5 48%, var(--color-primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    min-height: 3.3em;
    display: block;
  }
  [dir="rtl"] .hero__headline { font-family: var(--font-arabic-serif); }

  .hero__typewriter { display: inline; }

  .hero__cursor {
    display: inline;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.65);
    color: rgba(255, 255, 255, 0.65);
    font-weight: 300;
    margin-inline-start: 2px;
    animation: cursor-blink 1s step-end infinite;
  }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__cursor { animation: none; }
  }

  /* ── Sub ── */
  .hero__sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.62);
    margin-bottom: 2.25rem;
    max-width: 520px;
    line-height: 1.8;
  }

  /* ── Actions ── */
  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Visual (lottie) ── */
  .hero__visual {
    display: flex;
    justify-content: center;
  }
  .hero__image-wrap {
    position: relative;
    width: 100%;
    max-width: 460px;
  }
  /* Purple glow behind the animation */
  .hero__image-wrap::before {
    content: '';
    position: absolute;
    inset: -15%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(108, 63, 160, 0.35) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .hero__intro-img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius-xl);
    position: relative;
    z-index: 1;
    display: block;
  }

  /* ── Float badge (glass on dark) ── */
  .hero__badge-float {
    position: absolute;
    bottom: -1.5rem;
    left: -1.5rem;
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: var(--radius-lg);
    padding: 0.85rem 1.35rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.12);
    z-index: 2;
  }
  .hero__badge-float-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary-light));
    color: #FFFFFF;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 800;
  }

  /* ── Stats bar (dark glass) ── */
  .hero__stats {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    padding: 2.25rem 0;
  }
  .hero__stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
  }
  .hero__stat:last-child { border-right: none; }
  .hero__stat-value {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero__stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.48);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
    .hero__visual { display: none; }
    .hero__sub { margin-inline: auto; }
    .hero__actions { justify-content: center; }
    .hero__stats-grid { grid-template-columns: repeat(2, 1fr); }
    .hero__stat { border-right: none; }
  }
  @media (max-width: 480px) {
    .hero__stats-grid { grid-template-columns: repeat(2, 1fr); }
    .hero__headline { min-height: 4.5em; }
  }
</style>

<script>
  import gsap from 'gsap';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Count-up helper ── */
  function countUp(el: HTMLElement) {
    const target = parseInt(el.dataset.count ?? '0', 10);
    const before = el.dataset.before ?? '';
    const after  = el.dataset.after  ?? '';
    const obj = { val: 0 };
    gsap.to(obj, {
      val: target,
      duration: 2,
      ease: 'power2.out',
      onUpdate() { el.textContent = before + Math.round(obj.val) + after; },
      onComplete() { el.textContent = before + target + after; },
    });
  }

  /* ── Typewriter ── */
  function initTypewriter() {
    if (reduced) return;
    const maybeEl = document.getElementById('hero-typewriter');
    if (!maybeEl) return;
    const el: HTMLElement = maybeEl;
    const phrases: string[] = JSON.parse(el.dataset.phrases ?? '[]');
    if (phrases.length < 2) return;

    let phraseIdx = 0;
    let charIdx = phrases[0].length; // start already showing phrase 0
    let isDeleting = false;

    function tick() {
      const current = phrases[phraseIdx];

      if (!isDeleting && charIdx === current.length) {
        // Done typing — pause 2.2s then delete
        setTimeout(() => { isDeleting = true; tick(); }, 2200);
        return;
      }

      if (isDeleting && charIdx === 0) {
        // Done deleting — next phrase, pause 400ms
        phraseIdx = (phraseIdx + 1) % phrases.length;
        isDeleting = false;
        setTimeout(tick, 400);
        return;
      }

      if (isDeleting) {
        charIdx--;
        el.textContent = current.slice(0, charIdx);
        setTimeout(tick, 28);
      } else {
        charIdx++;
        el.textContent = phrases[phraseIdx].slice(0, charIdx);
        setTimeout(tick, 55);
      }
    }

    // Wait then start deleting the initial rendered phrase
    setTimeout(() => { isDeleting = true; tick(); }, 2200);
  }

  /* ── GSAP entrance ── */
  gsap.set('[data-gsap="hero-badge"]',       { autoAlpha: 0, y: 24 });
  gsap.set('[data-gsap="hero-headline"]',    { autoAlpha: 0, y: 32 });
  gsap.set('[data-gsap="hero-sub"]',         { autoAlpha: 0, y: 24 });
  gsap.set('[data-gsap="hero-actions"]',     { autoAlpha: 0, y: 20 });
  gsap.set('[data-gsap="hero-image"]',       { autoAlpha: 0, x: 40 });
  gsap.set('[data-gsap="hero-float-badge"]', { autoAlpha: 0, scale: 0.8 });
  gsap.set('[data-gsap="hero-stat"]',        { autoAlpha: 0, y: 20 });

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.1 });

  tl.to('[data-gsap="hero-badge"]',       { autoAlpha: 1, y: 0, duration: 0.55 })
    .to('[data-gsap="hero-headline"]',    { autoAlpha: 1, y: 0, duration: 0.7  }, '-=0.3')
    .to('[data-gsap="hero-sub"]',         { autoAlpha: 1, y: 0, duration: 0.55 }, '-=0.35')
    .to('[data-gsap="hero-actions"]',     { autoAlpha: 1, y: 0, duration: 0.5  }, '-=0.25')
    .to('[data-gsap="hero-image"]',       { autoAlpha: 1, x: 0, duration: 0.8  }, '-=0.7')
    .to('[data-gsap="hero-float-badge"]', { autoAlpha: 1, scale: 1, duration: 0.45, ease: 'back.out(1.4)' }, '-=0.3')
    .to('[data-gsap="hero-stat"]',        { autoAlpha: 1, y: 0, duration: 0.45, stagger: 0.1 }, '-=0.2')
    .add(() => {
      /* Count-up starts when stats animate in */
      document.querySelectorAll<HTMLElement>('.hero__stat-value[data-count]').forEach(countUp);
      /* Typewriter starts after headline is visible */
      initTypewriter();
    });
</script>
