---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const content = {
  en: {
    badge: 'How We Work',
    title: 'Our Process',
    sub: 'A transparent, structured approach that keeps you informed every step of the way.',
    cta: 'Start a Conversation',
    hint: 'Hover or tap a step to read more',
    steps: [
      {
        number: 1,
        icon: '💬',
        title: 'Free Consultation',
        description:
          'We listen carefully to understand your business, identify your challenges, and explain exactly how our services can help — no commitment required.',
      },
      {
        number: 2,
        icon: '📋',
        title: 'Engagement Planning',
        description:
          'We define the scope, agree on fees, and set a realistic timeline. You receive a clear engagement letter and meet your dedicated team.',
      },
      {
        number: 3,
        icon: '🔍',
        title: 'Fieldwork & Analysis',
        description:
          'Our ACCA-certified professionals perform the audit, accounting, or advisory work — rigorously and in compliance with international standards.',
      },
      {
        number: 4,
        icon: '📊',
        title: 'Report & Advisory',
        description:
          'You receive a professional report with clear findings, tax-saving opportunities, and actionable recommendations tailored to your business.',
      },
    ],
  },
  ar: {
    badge: 'كيف نعمل',
    title: 'منهجيتنا',
    sub: 'نهج شفاف ومنظم يُبقيك على اطلاع دائم في كل خطوة.',
    cta: 'ابدأ محادثة',
    hint: 'مرّر الفأرة أو اضغط على خطوة لقراءة التفاصيل',
    steps: [
      {
        number: 1,
        icon: '💬',
        title: 'استشارة مجانية',
        description:
          'نستمع بعناية لفهم عملك وتحديد تحدياتك وشرح كيف يمكن لخدماتنا مساعدتك — دون أي التزام مسبق.',
      },
      {
        number: 2,
        icon: '📋',
        title: 'تخطيط الارتباط',
        description:
          'نحدد النطاق ونتفق على الأتعاب ونضع جدولاً زمنياً واقعياً. ستتلقى خطاباً واضحاً وتلتقي بفريقك المخصص.',
      },
      {
        number: 3,
        icon: '🔍',
        title: 'أعمال الميدان والتحليل',
        description:
          'يُنفذ فريقنا المعتمد من ACCA عمليات التدقيق أو المحاسبة أو الاستشارة بدقة ووفقاً للمعايير الدولية.',
      },
      {
        number: 4,
        icon: '📊',
        title: 'التقرير والاستشارة',
        description:
          'تحصل على تقرير مهني بنتائج واضحة وفرص توفير ضريبي وتوصيات قابلة للتنفيذ مصممة خصيصاً لعملك.',
      },
    ],
  },
};

const c = content[l] ?? content.en;

// Anchor points (% of the track) the zigzag path passes through — the SVG
// path below uses the same coordinates (scaled to a 1000x200 viewBox) so
// each node sits exactly on the line.
const points = [
  { x: 4, y: 70 },
  { x: 32, y: 30 },
  { x: 60, y: 70 },
  { x: 88, y: 30 },
];
---

<section class="process section" id="process">
  <div class="process__bg" aria-hidden="true">
    <div class="process__orb process__orb--1"></div>
    <div class="process__orb process__orb--2"></div>
  </div>

  <div class="container">
    <div class="section-header" data-gsap="process-header">
      <span class="badge">{c.badge}</span>
      <h2>{c.title}</h2>
      <div class="divider"></div>
      <p>{c.sub}</p>
    </div>

    <div class="process__timeline" id="process-timeline">
      <div class="process__track">
        <!-- Curved connecting path: passes through each node's exact center -->
        <svg
          class="process__path"
          viewBox="0 0 1000 200"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            class="process__path-base"
            d="M 40,140 C 180,140 180,60 320,60 C 460,60 460,140 600,140 C 740,140 740,60 880,60"
            fill="none"
          />
          <path
            class="process__path-flow"
            d="M 40,140 C 180,140 180,60 320,60 C 460,60 460,140 600,140 C 740,140 740,60 880,60"
            fill="none"
            pathLength="1"
          />
        </svg>

        <ul class="process__steps">
          {c.steps.map((step, i) => (
            <li
              class="process__step"
              style={`--i:${i}; left:${points[i].x}%; top:${points[i].y}%;`}
              data-step={step.number}
            >
              <button type="button" class="process__node" aria-expanded="false">
                <span class="process__node-pulse" aria-hidden="true"></span>
                <span class="process__node-outer" aria-hidden="true"></span>
                <span class="process__node-inner" aria-hidden="true">
                  <span class="process__node-icon">{step.icon}</span>
                </span>
                <span class="sr-only">
                  {l === 'ar' ? `الخطوة ${step.number}: ${step.title}` : `Step ${step.number}: ${step.title}`}
                </span>
              </button>

              <div class="process__info">
                <span class="process__name">{step.title}</span>
                <p class="process__desc">{step.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="process__hint">{c.hint}</p>

    <div class="process__cta" data-gsap="process-cta">
      <a href="#contact" class="btn btn-primary">{c.cta}</a>
    </div>
  </div>
</section>

<style>
  .process {
    position: relative;
    background: var(--color-bg-alt);
    overflow: hidden;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ── Background orbs ── */
  .process__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .process__orb {
    position: absolute;
    border-radius: 50%;
  }
  .process__orb--1 {
    width: 520px; height: 520px;
    top: -120px; left: -220px;
    background: radial-gradient(circle, var(--color-primary-50) 0%, transparent 65%);
  }
  .process__orb--2 {
    width: 420px; height: 420px;
    bottom: -100px; right: -160px;
    background: radial-gradient(circle, var(--color-primary-50) 0%, transparent 65%);
  }

  /* ── Timeline wrapper ── */
  /* Fully responsive (no min-width) so the path, dots, and text are
     always visible without needing to scroll horizontally. */
  .process__timeline {
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
    padding-block: 2rem 8rem;
  }

  /* The track defines the exact coordinate box that both the SVG curve
     and the absolutely-positioned nodes share, so a node at left:X%/top:Y%
     always lands precisely on the matching point of the path. */
  .process__track {
    position: relative;
    width: 100%;
    height: 200px;
  }

  /* ── Curved SVG path ── */
  .process__path {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .process__path-base {
    stroke: var(--color-primary);
    stroke-width: 3;
    opacity: 0.9;
  }
  .process__path-flow {
    stroke: var(--color-primary-light);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 0.05 0.2;
    vector-effect: non-scaling-stroke;
    filter: drop-shadow(0 0 6px var(--color-primary-light));
    animation: process-flow 2.6s linear infinite;
  }

  @keyframes process-flow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -1; }
  }

  /* ── Steps: each node sits exactly on the curve at (--i)'s point ── */
  .process__steps {
    list-style: none;
    position: absolute;
    inset: 0;
  }

  .process__step {
    position: absolute;
    /* left/top set inline per step to match the path's coordinates */
  }

  /* ── Node (circle marker on the path) ── */
  .process__node {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 2;
  }

  .process__node-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    animation: process-pulse 2.4s ease-out infinite;
    animation-delay: calc(var(--i, 0) * 0.3s);
  }

  @keyframes process-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(176, 125, 228, 0.55); }
    70%  { box-shadow: 0 0 0 14px rgba(176, 125, 228, 0); }
    100% { box-shadow: 0 0 0 14px rgba(176, 125, 228, 0); }
  }

  .process__node-outer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .process__node-inner {
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    background: var(--color-bg-alt);
    border: 2px solid var(--color-primary-light);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .process__node-icon {
    font-size: 1.2rem;
    line-height: 1;
    pointer-events: none;
  }

  .process__node:hover .process__node-inner,
  .process__node:focus-visible .process__node-inner,
  .process__step.is-open .process__node-inner {
    transform: scale(1.1);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .process__node:focus-visible {
    outline: 2px solid var(--color-primary-light);
    outline-offset: 4px;
    border-radius: 50%;
  }

  /* ── Info block: name always visible, description on demand ── */
  .process__info {
    position: absolute;
    top: 36px;
    left: 50%;
    transform: translate(calc(-50% + var(--shift, 0px)), 0);
    width: max-content;
    max-width: 190px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    z-index: 3;
  }

  .process__name {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-dark);
    line-height: 1.3;
  }
  [dir="rtl"] .process__name { font-family: var(--font-arabic-serif); }

  .process__desc {
    font-size: 0.82rem;
    color: var(--color-text-medium);
    line-height: 1.6;
    margin-top: 0;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, opacity 0.25s ease, margin-top 0.35s ease;
  }

  .process__step:hover .process__desc,
  .process__step:focus-within .process__desc,
  .process__step.is-open .process__desc {
    max-height: 200px;
    opacity: 1;
    margin-top: 0.5rem;
  }

  /* ── Hint + CTA ── */
  .process__hint {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .process__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ── Responsive: shrink to fit, never requires horizontal scrolling ── */
  @media (max-width: 1100px) {
    .process__timeline {
      padding-inline: 2rem;
    }
  }

  @media (max-width: 640px) {
    .process__timeline {
      padding-block: 1.5rem 9rem;
      padding-inline: 0.5rem;
    }
    .process__track {
      height: 150px;
    }
    .process__node {
      width: 40px;
      height: 40px;
    }
    .process__node-icon { font-size: 0.95rem; }
    .process__info { top: 30px; max-width: 130px; }
    .process__name { font-size: 0.8rem; }
    .process__desc { font-size: 0.72rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .process__path-flow,
    .process__node-pulse {
      animation: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Section header slides in on enter
  ScrollTrigger.create({
    trigger: '#process',
    start: 'top 82%',
    once: true,
    onEnter: () => {
      gsap.fromTo(
        '[data-gsap="process-header"]',
        { autoAlpha: 0, y: 40 },
        { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out' }
      );
      gsap.fromTo(
        '[data-gsap="process-cta"]',
        { autoAlpha: 0, y: 20 },
        { autoAlpha: 1, y: 0, duration: 0.5, ease: 'power3.out', delay: 0.25 }
      );
    },
  });

  // Tap-to-toggle description support for touch devices
  const steps = document.querySelectorAll<HTMLElement>('.process__step');

  const closeAll = (except?: HTMLElement) => {
    steps.forEach((step) => {
      if (step !== except) {
        step.classList.remove('is-open');
        step.querySelector('.process__node')?.setAttribute('aria-expanded', 'false');
        step.querySelector<HTMLElement>('.process__info')?.style.removeProperty('--shift');
      }
    });
  };

  // Keep the info block fully inside the browser viewport so the full
  // description is always readable without needing to scroll.
  const clampInfo = (step: HTMLElement) => {
    const info = step.querySelector<HTMLElement>('.process__info');
    if (!info) return;
    info.style.setProperty('--shift', '0px');
    const rect = info.getBoundingClientRect();
    const margin = 12;
    let shift = 0;
    if (rect.left < margin) {
      shift = margin - rect.left;
    } else if (rect.right > window.innerWidth - margin) {
      shift = window.innerWidth - margin - rect.right;
    }
    info.style.setProperty('--shift', `${shift}px`);
  };

  steps.forEach((step) => {
    const node = step.querySelector('.process__node');
    node?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = step.classList.contains('is-open');
      closeAll(step);
      step.classList.toggle('is-open', !isOpen);
      node.setAttribute('aria-expanded', String(!isOpen));
      if (!isOpen) clampInfo(step);
    });
    step.addEventListener('mouseenter', () => clampInfo(step));
    step.addEventListener('focusin', () => clampInfo(step));
  });

  document.addEventListener('click', () => closeAll());
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });
</script>
