---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;

const nav = {
  en: [
    { label: 'Home',            href: '#intro' },
    { label: 'About',           href: '#about' },
    { label: 'Services',        href: '#services' },
    { label: 'Qualifications',  href: '#qualifications' },
    { label: 'Industries',      href: '#industries' },
    { label: 'Team',            href: '#team' },
    { label: 'Contact',         href: '#contact' },
  ],
  ar: [
    { label: 'الرئيسية',        href: '#intro' },
    { label: 'من نحن',          href: '#about' },
    { label: 'الخدمات',         href: '#services' },
    { label: 'المؤهلات',        href: '#qualifications' },
    { label: 'القطاعات',        href: '#industries' },
    { label: 'الفريق',          href: '#team' },
    { label: 'تواصل معنا',      href: '#contact' },
  ],
};

const links = nav[lang as keyof typeof nav] ?? nav.en;
const altLang = lang === 'ar' ? 'en' : 'ar';
const altHref = lang === 'ar' ? '/index.html' : '/index-a.html';
const altLabel = lang === 'ar' ? 'English' : 'عربي';
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href="#intro" class="header__logo">
      <img src="/images/logo2.png" alt="YG-Auditors Logo" width="44" height="44" />
      <span class="header__brand">YG<span>-Auditors</span></span>
    </a>

    <nav class="header__nav" id="nav">
      {links.map((link) => (
        <a href={link.href} class="header__nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="header__actions">
      <a href={altHref} class="header__lang">{altLabel}</a>
      <a href="#consultant" class="btn btn-primary header__cta">
        {lang === 'ar' ? 'استشارة مجانية' : 'Free Consultation'}
      </a>
      <button class="header__burger" id="burger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;
  }
  .header.scrolled {
    box-shadow: 0 4px 30px rgba(108, 63, 160, 0.12);
    border-bottom-color: rgba(108, 63, 160, 0.22);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }
  .header__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .header__logo img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    filter: none;
  }
  .header__brand {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.01em;
  }
  .header__brand span {
    color: var(--color-text-medium);
  }
  .header__nav {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    margin-inline-start: auto;
  }
  .header__nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: 0;
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--color-text-medium);
    transition: var(--transition);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .header__nav-link:hover {
    color: var(--color-primary);
  }
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .header__lang {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-light);
    border: 1px solid var(--color-border);
    padding: 0.35rem 0.85rem;
    border-radius: 0;
    transition: var(--transition);
    letter-spacing: 0.06em;
  }
  .header__lang:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .header__cta {
    padding: 0.5rem 1.25rem;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
  }
  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .header__burger span {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--color-primary);
    transition: var(--transition);
  }

  @media (max-width: 900px) {
    .header__nav {
      display: none;
      position: fixed;
      inset-block-start: 72px;
      inset-inline: 0;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(14px);
      padding: 1.5rem;
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-lg);
      gap: 0.25rem;
    }
    .header__nav.open { display: flex; }
    .header__nav-link { padding: 0.85rem 1rem; font-size: 1rem; width: 100%; }
    .header__burger { display: flex; }
    .header__cta { display: none; }
  }
</style>

<script>
  const header = document.getElementById('header');
  const burger = document.getElementById('burger');
  const nav = document.getElementById('nav');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  });

  burger?.addEventListener('click', () => {
    nav?.classList.toggle('open');
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => nav.classList.remove('open'));
  });
</script>
