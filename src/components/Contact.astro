---
import { getEntry } from 'astro:content';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const headingsEn = await getEntry('contactSection', 'en');
const headingsAr = await getEntry('contactSection', 'ar');
const h = (l === 'ar' ? headingsAr?.data : headingsEn?.data) ?? headingsEn!.data;

const contactInfoEntry = await getEntry('contactInfo', 'info');
const { contact, externalLinks } = contactInfoEntry!.data;
const address = contact.address[l] ?? contact.address.en;
const days = contact.workingHours.days[l] ?? contact.workingHours.days.en;
---

<section class="section section-alt" id="contact">
  <div class="container">
    <div class="section-header" data-gsap="contact-header">
      <span class="badge">{h.badge}</span>
      <h2>{h.title}</h2>
      <div class="divider"></div>
      <p>{h.sub}</p>
    </div>

    <div class="contact__grid">
      <div class="contact__info" data-gsap="contact-info">
        <div class="contact-item">
          <div class="contact-item__icon">📍</div>
          <div>
            <h4 class="contact-item__label">{l === 'ar' ? 'العنوان' : 'Address'}</h4>
            <p class="contact-item__value">{address}</p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-item__icon">📞</div>
          <div>
            <h4 class="contact-item__label">{l === 'ar' ? 'الهاتف' : 'Phone'}</h4>
            {contact.phones.map((phone) => (
              <a href={`tel:${phone.number.replace(/-/g, '')}`} class="contact-item__value contact-item__link">
                {phone.display}
              </a>
            ))}
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-item__icon">📧</div>
          <div>
            <h4 class="contact-item__label">{l === 'ar' ? 'البريد الإلكتروني' : 'Email'}</h4>
            <a href={`mailto:${contact.email}`} class="contact-item__value contact-item__link">
              {contact.email}
            </a>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-item__icon">🕐</div>
          <div>
            <h4 class="contact-item__label">{l === 'ar' ? 'ساعات العمل' : 'Working Hours'}</h4>
            <p class="contact-item__value">{days}</p>
            <p class="contact-item__value">{contact.workingHours.hours}</p>
          </div>
        </div>

        <div class="contact__social">
          <h4 class="contact__social-title">{l === 'ar' ? 'تابعنا' : 'Follow Us'}</h4>
          <div class="contact__social-links">
            <a href={contact.social.facebook.url} target="_blank" rel="noopener" class="social-btn social-btn--fb">
              <span>f</span> Facebook
            </a>
            <a href={contact.social.linkedin.url} target="_blank" rel="noopener" class="social-btn social-btn--li">
              <span>in</span> LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="contact__map" data-gsap="contact-map">
        <div class="contact__map-embed">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3452.4317!2d31.2835647!3d29.9702736!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1458392a7ede7cf9:0xfcebc3c5027597b6!2sYG-Auditors!5e0!3m2!1sen!2seg!4v1718548800000!5m2!1sen!2seg"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="YG-Auditors Office Location - Maadi, Cairo"
          ></iframe>
        </div>

        <div class="contact__external-links">
          <h4>{l === 'ar' ? 'روابط مفيدة' : 'Useful Links'}</h4>
          <div class="ext-links">
            {externalLinks.map((link) => (
              <a href={link.url} target="_blank" rel="noopener" class="ext-link">
                <span class="ext-link__arrow">↗</span>
                <div>
                  <span class="ext-link__name">{link.name}</span>
                  <span class="ext-link__desc">{link.description}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .contact-item__icon {
    width: 48px;
    height: 48px;
    background: var(--color-primary-50);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
    border: 1px solid var(--color-primary-100);
  }
  .contact-item__label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: 0.35rem;
  }
  .contact-item__value {
    font-size: 0.95rem;
    color: var(--color-text-medium);
    display: block;
    line-height: 1.6;
  }
  .contact-item__link {
    color: var(--color-text-dark);
    font-weight: 500;
    transition: var(--transition);
    text-decoration: none;
  }
  .contact-item__link:hover { color: var(--color-primary); }

  .contact__social { padding-top: 0.5rem; }
  .contact__social-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }
  .contact__social-links { display: flex; gap: 0.75rem; }
  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    transition: var(--transition);
    text-decoration: none;
  }
  .social-btn span {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
  }
  .social-btn--fb {
    background: #EEF2FF;
    color: #1877F2;
    border: 1px solid #C7D2FE;
  }
  .social-btn--fb span { background: #1877F2; color: white; }
  .social-btn--fb:hover { background: #1877F2; color: white; }
  .social-btn--li {
    background: #EEF6FB;
    color: #0A66C2;
    border: 1px solid #BFDBF7;
  }
  .social-btn--li span { background: #0A66C2; color: white; }
  .social-btn--li:hover { background: #0A66C2; color: white; }

  .contact__map {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .contact__map-embed {
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 300px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
  }

  .contact__external-links h4 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }
  .ext-links { display: flex; flex-direction: column; gap: 0.75rem; }
  .ext-link {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: var(--transition);
  }
  .ext-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-gold);
  }
  .ext-link__arrow {
    font-size: 1rem;
    color: var(--color-primary);
    margin-top: 0.1rem;
    flex-shrink: 0;
  }
  .ext-link__name {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-dark);
    margin-bottom: 0.15rem;
  }
  .ext-link__desc {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-light);
  }

  @media (max-width: 900px) {
    .contact__grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { lazyInitSection } from '../scripts/lazy-section';

  lazyInitSection('#contact', async () => {
    const gsap = (await import('gsap')).default;
    const { ScrollTrigger } = await import('gsap/ScrollTrigger');
    gsap.registerPlugin(ScrollTrigger);

    ScrollTrigger.create({
      trigger: '#contact',
      start: 'top 82%',
      once: true,
      onEnter: () => {
        gsap.fromTo('[data-gsap="contact-header"]',
          { autoAlpha: 0, y: 40 },
          { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out' }
        );
        gsap.fromTo('[data-gsap="contact-info"] .contact-item',
          { autoAlpha: 0, x: -40 },
          { autoAlpha: 1, x: 0, duration: 0.5, stagger: 0.12, ease: 'power3.out', delay: 0.2 }
        );
        gsap.fromTo('[data-gsap="contact-map"]',
          { autoAlpha: 0, x: 40 },
          { autoAlpha: 1, x: 0, duration: 0.75, ease: 'power3.out', delay: 0.1 }
        );
      },
    });
  });
</script>
