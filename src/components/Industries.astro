---
import industriesData from '../data/industries.json';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const headings = {
  en: { badge: 'Who We Serve', title: 'Industries We Serve', sub: 'Our expertise spans a broad range of sectors, from commercial businesses to non-profits and individual professionals.' },
  ar: { badge: 'من نخدم', title: 'القطاعات التي نخدمها', sub: 'تمتد خبرتنا عبر مجموعة واسعة من القطاعات من الشركات التجارية إلى المنظمات غير الربحية والمهنيين الأفراد.' },
};
const h = headings[l] ?? headings.en;

const catIcons: Record<string, string> = {
  'businesses': '🏢',
  'non-profit': '🤝',
  'individuals': '👤',
};
---

<section class="section section-dark industries-section" id="industries">
  <!-- Ambient floating orbs -->
  <div class="ind-ambient" aria-hidden="true">
    <div class="ind-orb ind-orb--1"></div>
    <div class="ind-orb ind-orb--2"></div>
  </div>

  <div class="container">
    <div class="section-header" data-gsap="industries-header">
      <span class="badge">{h.badge}</span>
      <h2>{h.title}</h2>
      <div class="divider"></div>
      <p>{h.sub}</p>
    </div>

    <div class="industries__grid">
      {industriesData.categories.map((cat, i) => (
        <div class="industry-card" style={`--i: ${i}`}>
          <div class="industry-card__header">
            <div class="industry-card__icon-wrap">
              <span class="industry-card__icon" aria-hidden="true">{catIcons[cat.id] ?? '📌'}</span>
            </div>
            <div>
              <h3 class="industry-card__title">{cat.title[l] ?? cat.title.en}</h3>
              <p class="industry-card__desc">{cat.description[l] ?? cat.description.en}</p>
            </div>
          </div>
          <div class="industry-card__tags">
            {cat.industries.map((ind) => (
              <span class="industry-tag">{ind[l] ?? ind.en}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .industries-section {
    position: relative;
    overflow: hidden;
  }

  /* ── Ambient orbs (more visible on dark) ── */
  .ind-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .ind-orb {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }
  .ind-orb--1 {
    width: 600px; height: 600px;
    top: -160px; left: -220px;
    background: radial-gradient(circle, rgba(108, 63, 160, 0.22) 0%, transparent 65%);
    animation: ind-orb-drift 11s ease-in-out infinite;
  }
  .ind-orb--2 {
    width: 420px; height: 420px;
    bottom: -100px; right: -160px;
    background: radial-gradient(circle, rgba(149, 97, 200, 0.18) 0%, transparent 65%);
    animation: ind-orb-drift 9s ease-in-out infinite reverse;
    animation-delay: -3s;
  }
  @keyframes ind-orb-drift {
    0%, 100% { translate: 0px 0px; scale: 1; }
    35%       { translate: -24px 36px; scale: 1.07; }
    70%       { translate: 18px -22px; scale: 0.93; }
  }

  /* ── Grid ── */
  .industries__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  /* ── Card (glass on dark) ── */
  .industry-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: var(--radius-md);
    padding: 2rem;
    position: relative;
    z-index: 0;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      transform 0.38s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.38s ease,
      border-color 0.3s ease,
      background 0.3s ease,
      filter 0.35s ease,
      opacity 0.35s ease;
    will-change: transform, box-shadow;
  }

  /* ── Glowing gradient border on hover ── */
  .industry-card::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: calc(var(--radius-md) + 2px);
    background: linear-gradient(
      135deg,
      rgba(108, 63, 160, 0.0),
      rgba(149, 97, 200, 1),
      rgba(200, 150, 255, 0.9),
      rgba(108, 63, 160, 0.0)
    );
    background-size: 300% 300%;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  @keyframes ind-border-flow {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .industry-card:hover::after {
    opacity: 1;
    animation: ind-border-flow 2.8s ease infinite;
  }

  /* ── Hover ── */
  .industry-card:hover {
    transform: translateY(-14px) scale(1.025);
    background: rgba(255, 255, 255, 0.09);
    box-shadow:
      0 30px 70px rgba(0, 0, 0, 0.5),
      0 0 60px rgba(108, 63, 160, 0.28);
    border-color: transparent;
  }

  /* ── Spotlight ── */
  .industries__grid:has(.industry-card:hover) .industry-card:not(:hover) {
    filter: brightness(0.45) saturate(0.5) blur(0.6px);
    transform: scale(0.96);
    opacity: 0.7;
  }
  .industries__grid:has(.industry-card:hover) .industry-card.is-breathing:not(:hover) {
    animation-play-state: paused;
  }

  /* ── Breathing ── */
  @keyframes ind-card-breathe {
    0%, 100% { box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2); }
    50%       { box-shadow: 0 6px 28px rgba(108, 63, 160, 0.22), 0 0 0 1px rgba(149, 97, 200, 0.12); }
  }
  .industry-card.is-breathing {
    animation: ind-card-breathe 3.6s ease-in-out infinite;
  }
  .industry-card.is-breathing:hover { animation: none; }

  /* ── Header row ── */
  .industry-card__header {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: flex-start;
  }

  /* ── Icon wrap ── */
  .industry-card__icon-wrap {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }
  .industry-card:hover .industry-card__icon-wrap {
    background: rgba(108, 63, 160, 0.35);
    border-color: rgba(149, 97, 200, 0.6);
    transform: scale(1.08) rotate(-3deg);
  }
  .industry-card__icon {
    font-size: 2rem;
    line-height: 1;
    pointer-events: none;
  }

  /* ── Text ── */
  .industry-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: var(--color-text-on-dark);
  }
  .industry-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-on-dark-muted);
    line-height: 1.5;
  }

  /* ── Tags ── */
  .industry-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .industry-tag {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.11);
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
  }
  .industry-tag:hover {
    background: var(--color-primary);
    color: #FFFFFF;
    border-color: var(--color-primary);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .industries__grid { grid-template-columns: 1fr; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .ind-orb { animation: none; }
    .industry-card {
      transition: box-shadow 0.2s ease, border-color 0.2s ease;
      will-change: auto;
    }
    .industry-card::after { display: none; }
    .industry-card:hover { transform: none; }
    .industry-card.is-breathing { animation: none; }
    .industries__grid:has(.industry-card:hover) .industry-card:not(:hover) {
      filter: none;
      transform: none;
      opacity: 1;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  ScrollTrigger.create({
    trigger: '#industries',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.fromTo('[data-gsap="industries-header"]',
        { autoAlpha: 0, y: 36 },
        { autoAlpha: 1, y: 0, duration: 0.65, ease: 'power3.out' }
      );

      const cards = gsap.utils.toArray<HTMLElement>('#industries .industry-card');

      gsap.fromTo(cards,
        { autoAlpha: 0, y: reduced ? 18 : 72, scale: reduced ? 1 : 0.88 },
        {
          autoAlpha: 1,
          y: 0,
          scale: 1,
          duration: reduced ? 0.35 : 0.75,
          stagger: reduced ? 0.08 : 0.14,
          ease: reduced ? 'power2.out' : 'power4.out',
          delay: 0.15,
          clearProps: 'transform',
        }
      ).then(() => {
        if (!reduced) {
          cards.forEach((card, i) => {
            setTimeout(() => card.classList.add('is-breathing'), i * 320);
          });
        }
      });

      /* Icon wrap pops in with a bounce */
      gsap.fromTo('#industries .industry-card__icon-wrap',
        { scale: 0, rotation: -15, autoAlpha: 0 },
        {
          scale: 1,
          rotation: 0,
          autoAlpha: 1,
          duration: reduced ? 0.25 : 0.55,
          stagger: reduced ? 0.08 : 0.14,
          ease: reduced ? 'power2.out' : 'back.out(2.8)',
          delay: reduced ? 0.2 : 0.42,
          clearProps: 'transform',
        }
      );
    },
  });
</script>
