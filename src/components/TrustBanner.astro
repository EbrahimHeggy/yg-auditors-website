---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const content = {
  en: {
    label: 'International Affiliation',
    title: 'Member Firm of PA Global',
    desc: 'YG Auditors is an officially registered member firm of PA Global — a leading international network of independent accounting and advisory firms. This affiliation brings global best practices, cross-border expertise, and international standards directly to our clients in Egypt.',
    pills: ['Global Standards', 'Local Expertise', 'International Reach'],
    cta: 'View our PA Global profile',
    card: {
      network: 'PA GLOBAL',
      tag: 'Official Member Firm',
      location: 'Egypt · Cairo',
    },
  },
  ar: {
    label: 'الانتساب الدولي',
    title: 'عضو في شبكة PA Global',
    desc: 'يُعدّ مكتب YG Auditors عضواً رسمياً في شبكة PA Global — إحدى الشبكات الدولية الرائدة للمكاتب المهنية المستقلة في المحاسبة والاستشارات. يُتيح هذا الانتساب أفضل الممارسات العالمية والخبرة الدولية مباشرةً لعملائنا في مصر.',
    pills: ['معايير دولية', 'خبرة محلية', 'امتداد عالمي'],
    cta: 'عرض ملفنا على PA Global',
    card: {
      network: 'PA GLOBAL',
      tag: 'شركة عضو رسمية',
      location: 'مصر · القاهرة',
    },
  },
};
const c = content[l] ?? content.en;
---

<section class="trust section" id="trust">
  <div class="trust__bg-shape" aria-hidden="true"></div>
  <div class="container trust__inner">

    <div class="trust__left" data-gsap="trust-left">
      <span class="badge">{c.label}</span>
      <h2 class="trust__title">{c.title}</h2>
      <div class="divider" style="margin-inline:0; margin-block: 1rem 1.75rem;"></div>
      <p class="trust__desc">{c.desc}</p>
      <div class="trust__pills">
        {c.pills.map((pill) => (
          <span class="trust__pill">
            <span class="trust__pill-check" aria-hidden="true">✓</span>
            {pill}
          </span>
        ))}
      </div>
      <a
        href="https://pa-global.com/locations/egypt/yg-auditors/"
        class="btn btn-outline trust__cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        {c.cta} ↗
      </a>
    </div>

    <div class="trust__right" data-gsap="trust-right">
      <div class="trust__card">
        <div class="trust__card-globe" aria-hidden="true">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" width="56" height="56">
            <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="2.5"/>
            <ellipse cx="32" cy="32" rx="13" ry="28" stroke="currentColor" stroke-width="2"/>
            <path d="M4 32H60" stroke="currentColor" stroke-width="2"/>
            <path d="M8 19H56M8 45H56" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/>
          </svg>
        </div>
        <div class="trust__card-body">
          <span class="trust__card-network">{c.card.network}</span>
          <span class="trust__card-tag">{c.card.tag}</span>
          <div class="trust__card-sep" aria-hidden="true"></div>
          <span class="trust__card-location">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" style="flex-shrink:0"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zm4.95.95a2 2 0 100 4 2 2 0 000-4z" clip-rule="evenodd"/></svg>
            {c.card.location}
          </span>
          <div class="trust__card-chips">
            <span class="trust__chip">ACCA Certified</span>
            <span class="trust__chip">Since 2015</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .trust {
    position: relative;
    background: var(--color-bg);
    overflow: hidden;
  }
  .trust__bg-shape {
    position: absolute;
    bottom: -180px;
    left: -180px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-primary-50) 0%, transparent 65%);
    border-radius: 50%;
    pointer-events: none;
  }

  .trust__inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .trust__title {
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--color-text-dark);
    margin-top: 1rem;
    line-height: 1.15;
  }
  [dir="rtl"] .trust__title { font-family: var(--font-arabic-serif); }
  .trust__desc {
    font-size: 1rem;
    color: var(--color-text-medium);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .trust__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 2rem;
  }
  .trust__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--color-primary-50);
    color: var(--color-primary-light);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-primary-100);
  }
  .trust__pill-check {
    color: var(--color-primary-light);
    font-weight: 800;
  }
  .trust__cta { align-self: flex-start; }

  /* Right card */
  .trust__card {
    background: linear-gradient(145deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    border-radius: var(--radius-xl);
    padding: 2.75rem 2.5rem;
    color: var(--color-white);
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
    overflow: hidden;
  }
  .trust__card::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
  }
  .trust__card__after {
    content: '';
    position: absolute;
    bottom: -40px;
    left: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
  }

  .trust__card-globe {
    color: rgba(255,255,255,0.5);
    line-height: 0;
  }
  .trust__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .trust__card-network {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--color-white);
    line-height: 1;
  }
  .trust__card-tag {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .trust__card-sep {
    width: 48px;
    height: 2px;
    background: rgba(255,255,255,0.25);
    border-radius: var(--radius-full);
    margin-block: 0.75rem;
  }
  .trust__card-location {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
    font-weight: 500;
  }
  .trust__card-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .trust__chip {
    background: rgba(255,255,255,0.12);
    color: var(--color-white);
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-full);
    backdrop-filter: blur(4px);
  }

  @media (max-width: 1024px) {
    .trust__inner { grid-template-columns: 1fr; gap: 3rem; }
    .trust__card { max-width: 480px; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.create({
    trigger: '#trust',
    start: 'top 82%',
    once: true,
    onEnter: () => {
      gsap.fromTo('[data-gsap="trust-left"]',
        { autoAlpha: 0, x: -50 },
        { autoAlpha: 1, x: 0, duration: 0.8, ease: 'power3.out' }
      );
      gsap.fromTo('[data-gsap="trust-right"]',
        { autoAlpha: 0, x: 50, scale: 0.96 },
        { autoAlpha: 1, x: 0, scale: 1, duration: 0.85, ease: 'power3.out', delay: 0.15 }
      );
    },
  });
</script>
