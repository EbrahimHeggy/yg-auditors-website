---
import { getEntry } from 'astro:content';
import LivingEarth from './LivingEarth.astro';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const en = await getEntry('services', 'en');
const ar = await getEntry('services', 'ar');
const c = (l === 'ar' ? ar?.data : en?.data) ?? en!.data;
---

<section class="section services-section" id="services">
  <div class="services-ambient" aria-hidden="true">
    <div class="services-orb services-orb--1"></div>
    <div class="services-orb services-orb--2"></div>
  </div>

  <div class="container services-grid">

    <!-- ── LEFT: services panel ── -->
    <div class="svc-panel">

      <div class="svc-header" data-gsap="services-header">
        <span class="badge">{c.badge}</span>
        <h2>{c.title}</h2>
        <div class="divider" style="margin-inline: 0; margin-block: 1rem 1.25rem;"></div>
        <p class="svc-sub">{c.sub}</p>
      </div>

      <ul class="svc-list">
        {c.services.map((s, i) => (
          <li class="svc-item" data-gsap="svc-item" style={`--i: ${i}`}>
            <span class="svc-num">{s.num}</span>
            <div class="svc-body">
              <h3 class="svc-name">{s.label}</h3>
              <p class="svc-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="svc-stats" data-gsap="services-stats">
        {c.stats.map((s, i) => (
          <>
            <div class="svc-stat">
              <span class="svc-stat__num">
                {s.num}<span class="svc-stat__plus">{s.plus}</span>
              </span>
              <span class="svc-stat__label">{s.label}</span>
            </div>
            {i < c.stats.length - 1 && <div class="svc-stat__sep" aria-hidden="true"></div>}
          </>
        ))}
      </div>

    </div>

    <!-- ── RIGHT: globe ── -->
    <div class="globe-col" data-gsap="services-globe">
      <LivingEarth id="services-earth" variant="panel" scrollTarget="#services" />
      <div class="globe-hint" id="globe-hint">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
          <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {c.hint}
      </div>
    </div>

  </div>
</section>

<script>
  import { lazyInitSection } from '../scripts/lazy-section';

  lazyInitSection('#services', async () => {
    const gsap = (await import('gsap')).default;
    const { ScrollTrigger } = await import('gsap/ScrollTrigger');
    gsap.registerPlugin(ScrollTrigger);

    /* ── GSAP scroll entrance ── */
    ScrollTrigger.create({
      trigger: '#services',
      start: 'top 80%',
      once: true,
      onEnter: () => {
        gsap.fromTo('[data-gsap="services-header"]',
          { autoAlpha: 0, x: -40 },
          { autoAlpha: 1, x: 0, duration: 0.7, ease: 'power3.out' }
        );
        gsap.fromTo('[data-gsap="svc-item"]',
          { autoAlpha: 0, x: -28 },
          { autoAlpha: 1, x: 0, duration: 0.5, stagger: 0.09, ease: 'power3.out', delay: 0.2 }
        );
        gsap.fromTo('[data-gsap="services-stats"] .svc-stat',
          { autoAlpha: 0, y: 18 },
          { autoAlpha: 1, y: 0, duration: 0.45, stagger: 0.09, ease: 'power3.out', delay: 0.55 }
        );
        gsap.fromTo('[data-gsap="services-globe"]',
          { autoAlpha: 0, scale: 0.92 },
          { autoAlpha: 1, scale: 1, duration: 0.9, ease: 'power3.out', delay: 0.15 }
        );
      },
    });
  });
</script>

<style>
  .services-section {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  /* ── Ambient orbs ── */
  .services-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .services-orb {
    position: absolute;
    border-radius: 50%;
  }
  .services-orb--1 {
    width: 560px; height: 560px;
    top: -200px; right: -80px;
    background: radial-gradient(circle, rgba(139,92,200,0.14) 0%, transparent 68%);
    animation: orb-drift 14s ease-in-out infinite;
  }
  .services-orb--2 {
    width: 380px; height: 380px;
    bottom: -120px; left: -120px;
    background: radial-gradient(circle, rgba(176,125,228,0.10) 0%, transparent 68%);
    animation: orb-drift 18s ease-in-out infinite reverse;
    animation-delay: -6s;
  }
  @keyframes orb-drift {
    0%, 100% { translate: 0 0; scale: 1; }
    40%       { translate: 24px -36px; scale: 1.06; }
    75%       { translate: -18px 24px; scale: 0.94; }
  }

  /* ── Two-column grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Left panel ── */
  .svc-panel {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .svc-sub {
    font-size: 0.97rem;
    color: var(--color-text-medium);
    line-height: 1.75;
  }

  /* Service list */
  .svc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .svc-item {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    padding: 1.1rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.22s ease, padding-inline 0.22s ease;
    border-radius: var(--radius-sm);
    cursor: default;
  }
  .svc-item:first-child { border-top: 1px solid var(--color-border); }
  .svc-item:hover {
    background: rgba(139, 92, 200, 0.07);
    padding-inline: 0.9rem;
  }
  .svc-num {
    font-family: var(--font-serif);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-primary-light);
    letter-spacing: 0.10em;
    flex-shrink: 0;
    padding-top: 0.22rem;
    min-width: 26px;
  }
  .svc-body { flex: 1; }
  .svc-name {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }
  .svc-desc {
    font-size: 0.83rem;
    color: var(--color-text-medium);
    line-height: 1.65;
  }

  /* Stats row */
  .svc-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }
  .svc-stat { text-align: center; }
  .svc-stat__num {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }
  .svc-stat__plus {
    color: var(--color-primary-light);
    -webkit-text-fill-color: var(--color-primary-light);
    font-size: 0.75em;
  }
  .svc-stat__label {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-on-dark-muted);
    margin-top: 0.3rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .svc-stat__sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.09);
    flex-shrink: 0;
  }

  /* ── Right: globe column ── */
  .globe-col {
    position: relative;
    height: 580px;
  }

  .globe-hint {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10.5px;
    font-weight: 500;
    color: rgba(200, 185, 230, 0.45);
    letter-spacing: 0.06em;
    pointer-events: none;
    z-index: 3;
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .globe-col {
      height: 420px;
    }
    .svc-stat__sep { display: none; }
  }
  @media (max-width: 480px) {
    .globe-col { height: 340px; }
    .svc-stats { gap: 1.2rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .services-orb { animation: none; }
  }
</style>
