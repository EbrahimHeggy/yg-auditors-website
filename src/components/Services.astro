---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const l = lang as 'en' | 'ar';

const content = {
  en: {
    badge: 'What We Offer',
    title: 'Our Services',
    sub: 'Delivered across 15+ cities in Egypt with international reach through the PA Global network.',
    hint: 'Drag to rotate',
    services: [
      {
        num: '01',
        label: 'Audit & Assurance',
        desc: 'Independent examination of financial statements ensuring accuracy, regulatory compliance, and stakeholder confidence.',
      },
      {
        num: '02',
        label: 'Tax Advisory',
        desc: 'Strategic tax planning, filing, and compliance services tailored to Egyptian tax law and international standards.',
      },
      {
        num: '03',
        label: 'Accounting Outsourcing',
        desc: 'Full-cycle bookkeeping, payroll processing, and financial reporting so you can focus on growing your business.',
      },
      {
        num: '04',
        label: 'Social Insurance',
        desc: 'Registration, calculation, and compliance management for employee social insurance obligations.',
      },
      {
        num: '05',
        label: 'Business Setup',
        desc: 'End-to-end company formation, licensing, and regulatory registration across Egypt.',
      },
    ],
    stats: [
      { num: '10',   plus: '+', label: 'Years Active' },
      { num: '100',  plus: '+', label: 'Clients Served' },
      { num: '15',   plus: '+', label: 'Cities Covered' },
      { num: 'ACCA', plus: '',  label: 'Certified' },
    ],
  },
  ar: {
    badge: 'ما نقدمه',
    title: 'خدماتنا',
    sub: 'نخدم أكثر من 15 مدينة في مصر مع امتداد دولي عبر شبكة PA Global.',
    hint: 'اسحب للتدوير',
    services: [
      {
        num: '01',
        label: 'تدقيق وتأكيد',
        desc: 'فحص مستقل للقوائم المالية لضمان الدقة والامتثال التنظيمي وثقة أصحاب المصلحة.',
      },
      {
        num: '02',
        label: 'استشارات ضريبية',
        desc: 'تخطيط ضريبي استراتيجي وتقديم الإقرارات والامتثال وفقاً للقانون الضريبي المصري والمعايير الدولية.',
      },
      {
        num: '03',
        label: 'مسك الدفاتر',
        desc: 'خدمات محاسبية متكاملة وكشوف رواتب وتقارير مالية حتى تتفرغ لتنمية أعمالك.',
      },
      {
        num: '04',
        label: 'تأمينات اجتماعية',
        desc: 'تسجيل وحساب وإدارة الامتثال لالتزامات التأمينات الاجتماعية للموظفين.',
      },
      {
        num: '05',
        label: 'تأسيس الأعمال',
        desc: 'تأسيس الشركات والتراخيص والتسجيل التنظيمي من الألف إلى الياء في جميع أنحاء مصر.',
      },
    ],
    stats: [
      { num: '10',   plus: '+', label: 'سنوات نشاط' },
      { num: '100',  plus: '+', label: 'عميل تم خدمته' },
      { num: '15',   plus: '+', label: 'مدينة مغطاة' },
      { num: 'ACCA', plus: '',  label: 'معتمد دولياً' },
    ],
  },
};

const c = content[l] ?? content.en;
---

<section class="section services-section" id="services">
  <div class="services-ambient" aria-hidden="true">
    <div class="services-orb services-orb--1"></div>
    <div class="services-orb services-orb--2"></div>
  </div>

  <div class="container services-grid">

    <!-- ── LEFT: services panel ── -->
    <div class="svc-panel">

      <div class="svc-header" data-gsap="services-header">
        <span class="badge">{c.badge}</span>
        <h2>{c.title}</h2>
        <div class="divider" style="margin-inline: 0; margin-block: 1rem 1.25rem;"></div>
        <p class="svc-sub">{c.sub}</p>
      </div>

      <ul class="svc-list">
        {c.services.map((s, i) => (
          <li class="svc-item" data-gsap="svc-item" style={`--i: ${i}`}>
            <span class="svc-num">{s.num}</span>
            <div class="svc-body">
              <h3 class="svc-name">{s.label}</h3>
              <p class="svc-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="svc-stats" data-gsap="services-stats">
        {c.stats.map((s, i) => (
          <>
            <div class="svc-stat">
              <span class="svc-stat__num">
                {s.num}<span class="svc-stat__plus">{s.plus}</span>
              </span>
              <span class="svc-stat__label">{s.label}</span>
            </div>
            {i < c.stats.length - 1 && <div class="svc-stat__sep" aria-hidden="true"></div>}
          </>
        ))}
      </div>

    </div>

    <!-- ── RIGHT: globe ── -->
    <div class="globe-col" data-gsap="services-globe">
      <canvas id="globe-canvas"></canvas>
      <div class="globe-hint" id="globe-hint">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
          <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {c.hint}
      </div>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Canvas ── */
  const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  let W: number, H: number, cx: number, cy: number, R: number;

  function resize() {
    const rect = canvas.getBoundingClientRect();
    const dpr  = window.devicePixelRatio || 1;
    W = rect.width; H = rect.height;
    canvas.width  = W * dpr;
    canvas.height = H * dpr;
    ctx.scale(dpr, dpr);
    cx = W / 2;
    cy = H / 2;
    R  = Math.min(W, H) * 0.42;
  }
  resize();
  window.addEventListener('resize', resize);


  /* ── Spotlight: random positions all over the globe, labeled with Egyptian cities ── */
  const EGYPT_CITY_NAMES = [
    'Cairo', 'Alexandria', 'Giza', 'Luxor', 'Aswan',
    'Port Said', 'Suez', 'Mansoura', 'Tanta', 'Zagazig',
    'Ismailia', 'Damietta', 'Sohag', 'Hurghada', 'Sharm El-Sheikh',
    'Marsa Matruh', 'Borg El Arab', 'Minya', 'Beni Suef', 'Qena',
    'Asyut', 'Fayoum', 'Kafr El-Sheikh', 'Gharbia', 'Beheira',
    'Sharqia', 'Dakahlia', 'Monufia', 'Helwan', 'El-Mahalla',
    '6th of October', 'Shubra El-Kheima', 'New Cairo', 'Ras Gharib',
  ];

  interface SpotlightPt { x: number; y: number; z: number; name: string; bornAt: number; }
  let spotlightPts: SpotlightPt[] = [];
  let lastSpotlight  = 0;
  const SPOTLIGHT_COUNT    = 6;
  const SPOTLIGHT_INTERVAL = 650;   // one new point every 650 ms
  const SPOTLIGHT_LIFETIME = 4000;  // each point lives 4 s total
  const SPOTLIGHT_FADE     = 480;   // fade-in / fade-out duration

  function randomOnSphere(): { x: number; y: number; z: number } {
    const u     = Math.random() * 2 - 1;
    const theta = Math.random() * Math.PI * 2;
    const r     = Math.sqrt(1 - u * u);
    return { x: r * Math.cos(theta), y: u, z: r * Math.sin(theta) };
  }

  function refreshSpotlight(now: number) {
    // Drop expired points
    spotlightPts = spotlightPts.filter(sp => now - sp.bornAt < SPOTLIGHT_LIFETIME);

    // Add one new point per interval, stop when at max
    if (now - lastSpotlight < SPOTLIGHT_INTERVAL) return;
    if (spotlightPts.length >= SPOTLIGHT_COUNT) return;
    lastSpotlight = now;

    const usedNames = new Set(spotlightPts.map(s => s.name));
    const available = EGYPT_CITY_NAMES.filter(n => !usedNames.has(n));
    if (available.length === 0) return;

    let attempts = 0;
    while (attempts < 30) {
      attempts++;
      const pos = randomOnSphere();
      const rp  = rotate(pos, phi, rotX);
      if (rp.z < 0.25) continue;
      const name = available[Math.floor(Math.random() * available.length)];
      spotlightPts.push({ ...pos, name, bornAt: now });
      break;
    }
  }

  let phi  = -0.545; // centres ~31°E (Egypt)
  let rotX =  0.48;  // tilts ~27°N into view
  let dragging = false, lastX = 0, lastY = 0, velX = 0;

  /* ── Math helpers ── */
  function rotate(p: { x: number; y: number; z: number }, aY: number, aX: number) {
    const x1 =  p.x * Math.cos(aY) + p.z * Math.sin(aY);
    const z1 = -p.x * Math.sin(aY) + p.z * Math.cos(aY);
    const y2 =  p.y * Math.cos(aX) - z1 * Math.sin(aX);
    const z2 =  p.y * Math.sin(aX) + z1 * Math.cos(aX);
    return { x: x1, y: y2, z: z2 };
  }
  function project(p: { x: number; y: number; z: number }) {
    return { x: cx + p.x * R, y: cy - p.y * R, vis: p.z };
  }

  /* ── Globe dots ── */
  function drawDots() {
    const total = 3600;
    for (let i = 0; i < total; i++) {
      const phi2   = Math.acos(1 - (2 * i) / total);
      const theta2 = Math.PI * (1 + Math.sqrt(5)) * i;
      const raw    = {
        x: Math.sin(phi2) * Math.cos(theta2),
        y: Math.cos(phi2),
        z: Math.sin(phi2) * Math.sin(theta2),
      };
      const rp = rotate(raw, phi, rotX);
      const p  = project(rp);
      if (p.vis < 0) continue;
      const alpha = 0.10 + p.vis * 0.50;
      const size  = 0.60 + p.vis * 0.80;
      const r = Math.floor(85  + p.vis * 55);
      const g = Math.floor(45  + p.vis * 38);
      const b = Math.floor(170 + p.vis * 58);
      ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
      ctx.fill();
    }
  }


  /* ── Spotlight labels at random positions across the entire globe ── */
  function drawSpotlights() {
    const now = Date.now();
    refreshSpotlight(now);
    spotlightPts.forEach((sp) => {
      const rp = rotate(sp, phi, rotX);
      if (rp.z < 0.15) return;
      const p   = project(rp);

      const age     = now - sp.bornAt;
      const fadeIn  = Math.min(1, age / SPOTLIGHT_FADE);
      const fadeOut = age > SPOTLIGHT_LIFETIME - SPOTLIGHT_FADE
        ? Math.max(0, (SPOTLIGHT_LIFETIME - age) / SPOTLIGHT_FADE)
        : 1;
      const alpha = Math.min(1, (rp.z - 0.15) / 0.30) * fadeIn * fadeOut;
      if (alpha <= 0.01) return;
      const core  = 4;

      // Pulse ring
      ctx.strokeStyle = `rgba(200,150,255,${alpha * 0.45})`;
      ctx.lineWidth   = 0.9;
      ctx.beginPath();
      ctx.arc(p.x, p.y, core * 2.2, 0, Math.PI * 2);
      ctx.stroke();

      // Filled dot
      ctx.fillStyle = `rgba(185,105,255,${alpha * 0.90})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, core, 0, Math.PI * 2);
      ctx.fill();

      // Bright core
      ctx.fillStyle = `rgba(230,210,255,${alpha * 0.85})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, core * 0.35, 0, Math.PI * 2);
      ctx.fill();

      // Label pill
      const LY = -core * 3 - 14;
      ctx.save();
      ctx.font = '600 9.5px Inter, system-ui, sans-serif';
      ctx.textAlign = 'center';
      const tw = ctx.measureText(sp.name).width;
      const pw = tw + 14, ph = 16;
      const px = p.x - pw / 2, py = p.y + LY - ph + 2;

      ctx.globalAlpha = alpha * 0.88;
      ctx.fillStyle   = 'rgba(6,7,20,0.90)';
      ctx.strokeStyle = 'rgba(139,92,200,0.55)';
      ctx.lineWidth   = 0.8;
      ctx.beginPath();
      if (ctx.roundRect) ctx.roundRect(px, py, pw, ph, 5);
      else ctx.rect(px, py, pw, ph);
      ctx.fill();
      ctx.stroke();

      ctx.globalAlpha = alpha * 0.50;
      ctx.strokeStyle = 'rgba(176,125,228,0.7)';
      ctx.lineWidth   = 0.7;
      ctx.beginPath();
      ctx.moveTo(p.x, p.y - core);
      ctx.lineTo(p.x, py + ph);
      ctx.stroke();

      ctx.globalAlpha = alpha;
      ctx.fillStyle   = 'rgba(220,200,255,0.95)';
      ctx.fillText(sp.name, p.x, py + ph - 4);
      ctx.restore();
    });
  }

  /* ── Edge vignette ── */
  function drawVignette() {
    const g = ctx.createRadialGradient(cx, cy, R * 0.62, cx, cy, R * 1.08);
    g.addColorStop(0, 'rgba(8,9,26,0)');
    g.addColorStop(1, 'rgba(8,9,26,0.55)');
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.arc(cx, cy, R * 1.08, 0, Math.PI * 2);
    ctx.fill();
  }

  /* ── Render loop ── */
  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Sphere outline
    ctx.strokeStyle = 'rgba(139,92,200,0.14)';
    ctx.lineWidth   = 0.8;
    ctx.beginPath();
    ctx.arc(cx, cy, R, 0, Math.PI * 2);
    ctx.stroke();

    drawDots();
    drawSpotlights();
    drawVignette();

    if (!dragging) phi += 0.0018;
    if (!dragging && Math.abs(velX) > 0.0001) {
      phi  += velX;
      velX *= 0.92;
    }

    requestAnimationFrame(draw);
  }

  draw();

  /* ── Pointer drag ── */
  canvas.addEventListener('pointerdown', (e) => {
    dragging = true; lastX = e.clientX; lastY = e.clientY; velX = 0;
    canvas.setPointerCapture(e.pointerId);
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    const dx = e.clientX - lastX, dy = e.clientY - lastY;
    velX = dx * 0.005; phi += dx * 0.005;
    rotX = Math.max(-1.2, Math.min(1.2, rotX + dy * 0.003));
    lastX = e.clientX; lastY = e.clientY;
  });
  const endDrag = () => { dragging = false; };
  canvas.addEventListener('pointerup',     endDrag);
  canvas.addEventListener('pointercancel', endDrag);
  canvas.addEventListener('touchmove', (e) => {
    if (!dragging || !e.touches[0]) return;
    const dx = e.touches[0].clientX - lastX, dy = e.touches[0].clientY - lastY;
    phi  += dx * 0.005;
    rotX  = Math.max(-1.2, Math.min(1.2, rotX + dy * 0.003));
    lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
  }, { passive: true });

  /* ── GSAP scroll entrance ── */
  ScrollTrigger.create({
    trigger: '#services',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      gsap.fromTo('[data-gsap="services-header"]',
        { autoAlpha: 0, x: -40 },
        { autoAlpha: 1, x: 0, duration: 0.7, ease: 'power3.out' }
      );
      gsap.fromTo('[data-gsap="svc-item"]',
        { autoAlpha: 0, x: -28 },
        { autoAlpha: 1, x: 0, duration: 0.5, stagger: 0.09, ease: 'power3.out', delay: 0.2 }
      );
      gsap.fromTo('[data-gsap="services-stats"] .svc-stat',
        { autoAlpha: 0, y: 18 },
        { autoAlpha: 1, y: 0, duration: 0.45, stagger: 0.09, ease: 'power3.out', delay: 0.55 }
      );
      gsap.fromTo('[data-gsap="services-globe"]',
        { autoAlpha: 0, scale: 0.92 },
        { autoAlpha: 1, scale: 1, duration: 0.9, ease: 'power3.out', delay: 0.15 }
      );
    },
  });
</script>

<style>
  .services-section {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  /* ── Ambient orbs ── */
  .services-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .services-orb {
    position: absolute;
    border-radius: 50%;
  }
  .services-orb--1 {
    width: 560px; height: 560px;
    top: -200px; right: -80px;
    background: radial-gradient(circle, rgba(139,92,200,0.14) 0%, transparent 68%);
    animation: orb-drift 14s ease-in-out infinite;
  }
  .services-orb--2 {
    width: 380px; height: 380px;
    bottom: -120px; left: -120px;
    background: radial-gradient(circle, rgba(176,125,228,0.10) 0%, transparent 68%);
    animation: orb-drift 18s ease-in-out infinite reverse;
    animation-delay: -6s;
  }
  @keyframes orb-drift {
    0%, 100% { translate: 0 0; scale: 1; }
    40%       { translate: 24px -36px; scale: 1.06; }
    75%       { translate: -18px 24px; scale: 0.94; }
  }

  /* ── Two-column grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Left panel ── */
  .svc-panel {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .svc-sub {
    font-size: 0.97rem;
    color: var(--color-text-medium);
    line-height: 1.75;
  }

  /* Service list */
  .svc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .svc-item {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    padding: 1.1rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.22s ease, padding-inline 0.22s ease;
    border-radius: var(--radius-sm);
    cursor: default;
  }
  .svc-item:first-child { border-top: 1px solid var(--color-border); }
  .svc-item:hover {
    background: rgba(139, 92, 200, 0.07);
    padding-inline: 0.9rem;
  }
  .svc-num {
    font-family: var(--font-serif);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-primary-light);
    letter-spacing: 0.10em;
    flex-shrink: 0;
    padding-top: 0.22rem;
    min-width: 26px;
  }
  .svc-body { flex: 1; }
  .svc-name {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }
  .svc-desc {
    font-size: 0.83rem;
    color: var(--color-text-medium);
    line-height: 1.65;
  }

  /* Stats row */
  .svc-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }
  .svc-stat { text-align: center; }
  .svc-stat__num {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }
  .svc-stat__plus {
    color: var(--color-primary-light);
    -webkit-text-fill-color: var(--color-primary-light);
    font-size: 0.75em;
  }
  .svc-stat__label {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-on-dark-muted);
    margin-top: 0.3rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .svc-stat__sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.09);
    flex-shrink: 0;
  }

  /* ── Right: globe column ── */
  .globe-col {
    position: relative;
    height: 580px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: radial-gradient(circle at 48% 44%, #111228 0%, #08091A 100%);
    border: 1px solid rgba(139, 92, 200, 0.14);
  }

  #globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }
  #globe-canvas:active { cursor: grabbing; }

  .globe-hint {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10.5px;
    font-weight: 500;
    color: rgba(200, 185, 230, 0.45);
    letter-spacing: 0.06em;
    pointer-events: none;
    z-index: 3;
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .globe-col {
      height: 420px;
    }
    .svc-stat__sep { display: none; }
  }
  @media (max-width: 480px) {
    .globe-col { height: 340px; }
    .svc-stats { gap: 1.2rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .services-orb { animation: none; }
  }
</style>
